{
  "expo": {
    "name": "HealthUnity-frontend",
    "slug": "HealthUnity-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Health-PNG-Image-HD.png",
    "scheme": "healthunityfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.HealthUnityfrontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Health-PNG-Image-HD.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.HealthUnityfrontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Health-PNG-Image-HD.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563eb"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
