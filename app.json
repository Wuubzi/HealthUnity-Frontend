{
  "expo": {
    "name": "HealthUnity-frontend",
    "slug": "HealthUnity-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "https://res.cloudinary.com/dbfbj9gu3/image/upload/v1763062195/WhatsApp_Image_2025-11-04_at_10.52.28_PM-removebg-preview_dbu91s.png",
    "scheme": "healthunityfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.HealthUnityfrontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "https://res.cloudinary.com/dbfbj9gu3/image/upload/v1763062195/WhatsApp_Image_2025-11-04_at_10.52.28_PM-removebg-preview_dbu91s.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.HealthUnityfrontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "https://res.cloudinary.com/dbfbj9gu3/image/upload/v1763062195/WhatsApp_Image_2025-11-04_at_10.52.28_PM-removebg-preview_dbu91s.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563eb"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c0ac10d-47fe-4f5d-a7c4-0a8b3b792869"
      }
    }
  }
}
